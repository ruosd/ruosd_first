# ============================================
# 多Agent电商客服系统 - 环境配置模板
# 使用方式:
#   1. 复制此文件为 .env
#   2. 修改必填项（标记为 ★ 的字段）
#   3. 其他字段有安全默认值，按需调整
# ============================================

# ★ 阿里云百炼配置（请替换为你的 API 密钥）
ALIYUN_API_KEY=your_api_key_here
ALIYUN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_MODEL_NAME=deepseek-v4-pro

# Redis 配置（Docker 内默认用服务名 redis）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MySQL 配置（Docker 内默认用服务名 mysql）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=admin
MYSQL_PASSWORD=password
MYSQL_DB=ecommerce

# JWT 密钥（生产环境必须替换为随机字符串）
JWT_SECRET_KEY=change_me_to_random_string_32chars
ADMIN_JWT_SECRET_KEY=change_me_to_another_random_string_32chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_secure_password

# CORS 允许的前端来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 日志 & 端口
LOG_LEVEL=INFO
APP_PORT=8000

# ==================== 记忆系统配置 ====================

# Ollama 配置（用于本地嵌入，Docker 内默认用 host.docker.internal）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3:latest
OLLAMA_TIMEOUT=30

# ChromaDB 配置
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_ANONYMIZED_TELEMETRY=false

# 记忆系统
MEMORY_ENABLED=true
SHORT_TERM_MEMORY_TTL=86400
LONG_TERM_MEMORY_RETENTION_DAYS=90
TOP_K_RETRIEVAL=5
MEMORY_IMPORTANCE_THRESHOLD=0.6

# ChromaDB 集合名称
CHROMA_COLLECTION_SHORT_TERM=short_term_memory
CHROMA_COLLECTION_LONG_TERM=long_term_memory
CHROMA_COLLECTION_KNOWLEDGE=knowledge_base
CHROMA_COLLECTION_PRODUCT=product_memory
